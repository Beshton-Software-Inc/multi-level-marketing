DATABASE_URL=postgresql://user:password@localhost/winwinlaw_mlm
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Shared secret for the server-to-server webhook from winwinlaw backend.
# Must match MLM_WEBHOOK_SECRET in the winwinlaw backend .env.
MLM_WEBHOOK_SECRET=change-this-shared-secret
